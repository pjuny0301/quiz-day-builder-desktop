{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Quiz Day Builder",
  "version": "0.1.0",
  "identifier": "com.quizday.builder",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "덱 관리",
        "width": 960,
        "height": 800,
        "minWidth": 860,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
